# ─── BACKEND ────────────────────────────────────────────────────────────────

# Puerto donde corre el servidor Express
PORT=3000

# URI de conexión a MongoDB (se configura en Fase C)
# Formato local:  mongodb://localhost:27017/crunchymark
# Formato Atlas:  mongodb+srv://usuario:password@cluster.mongodb.net/crunchymark?appName=crunchymark
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/crunchymark?appName=crunchymark

# Clave secreta para firmar los tokens JWT (se configura en Fase C)
# IMPORTANTE: usar un string largo y aleatorio, nunca una palabra simple
# Ejemplo para generar uno: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=reemplaza_esto_con_un_string_largo_y_aleatorio

# Tiempo de expiración del token JWT
# Formato: número + unidad (s=segundos, m=minutos, h=horas, d=días)
JWT_EXPIRES_IN=7d

# ─── FRONTEND ───────────────────────────────────────────────────────────────

# URL base de la API del backend (usada por Axios en Fase D)
# En desarrollo apunta al backend local
VITE_API_URL=http://localhost:3000

# URL del servidor de WebSockets (usada por Socket.io en Fase F)
# En desarrollo apunta al mismo servidor que la API
VITE_SOCKET_URL=http://localhost:3000
